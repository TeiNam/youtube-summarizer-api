# AWS 자격 증명
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# API 인증키
API_KEY=your-api-key-here

# API 경로 프리픽스 (예: /yts/api)
API_PREFIX=
# 리버스 프록시 root_path (Swagger UI 경로 보정용)
ROOT_PATH=

# AWS Bedrock 설정
# 요약 품질을 높이려면 Opus 4.8 권장: anthropic.claude-opus-4-8
# (계정이 인퍼런스 프로파일을 쓰면 us.anthropic.claude-opus-4-8)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# 추론 강도 (low|medium|high|max). 비워두면 미적용.
# Opus 4.8/4.6·Sonnet 4.6에서만 지원 — Haiku·구형 모델에서는 반드시 비워둘 것.
# 요약은 medium 권장 (비용 절감 시 low).
BEDROCK_EFFORT=

# AWS Transcribe 설정 (음성 인식 폴백용)
TRANSCRIBE_S3_BUCKET=youtube-summary-audio
TRANSCRIBE_POLL_INTERVAL=5
TRANSCRIBE_MAX_WAIT_TIME=600
